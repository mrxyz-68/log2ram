#!/bin/sh

rm -rf /var/log.hdd
rm -rf /var/hdd.log

source /etc/conf.d/log2ram

if [ -n "$(du -sh -t $SIZE /var/log | cut -f1)" ]; then
    echo "WARNING: Variable SIZE in /etc/log2ram.conf is too small to store the /var/log/"
    echo -n "Actual size of /var/log is:"
    du -sh /var/log
    echo -e "\nPlease increase SIZE in /etc/log2ram.conf to avoid issues"
fi

cat >&2 <<-EOF
* Reboot to activate log2ram
* Edit /etc/conf.d/log2ram to configure options
EOF
